{
    "name": "tuijncode/laravel-waf",
    "description": "A Web Application Firewall (WAF) for Laravel.",
    "keywords": [
        "laravel",
        "waf",
        "web-application-firewall"
    ],
    "homepage": "https://github.com/tuijncode/laravel-waf",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "David van der Tuijn",
            "email": "davidvandertuijn@mac.com"
        }
    ],
    "require": {
        "php": ">=8.2.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Tuijncode\\LaravelWaf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tuijncode\\LaravelWaf\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tuijncode\\LaravelWaf\\WafServiceProvider"
            ],
            "aliases": {
                "Waf": "Tuijncode\\LaravelWaf\\Facades\\Waf"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint",
        "test:style": "vendor/bin/pint --test",
        "test:types": "vendor/bin/phpstan analyse --no-progress --memory-limit=512M"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
